{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "J-Link Debug",
            "type": "cortex-debug",
            "request": "launch",
            "servertype": "jlink",
            "cwd": "${workspaceFolder}",
            "executable": "build/rtthread.elf",
            "armToolchainPath": "${workspaceFolder}/toolchain_bin",
            "device": "R7FA8D1BH",
            "interface": "swd",
            "runToEntryPoint": "Reset_Handler",
            "preLaunchTask": "build",
            "svdFile": "", 
            "showDevDebugOutput": "none"
        },
        {
            "name": "PyOCD Debug (DAP-Link)",
            "type": "cortex-debug",
            "request": "launch",
            "servertype": "pyocd",
            "cwd": "${workspaceFolder}",
            "executable": "build/rtthread.elf",
            "armToolchainPath": "${workspaceFolder}/toolchain_bin",
            "targetId": "r7fa8d1bh",
            "runToEntryPoint": "Reset_Handler",
            "preLaunchTask": "build"
        }
    ]
}
